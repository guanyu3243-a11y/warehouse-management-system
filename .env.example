# Copy this file to .env before running docker compose.
# Replace every change-me value before using it outside local testing.

COMPOSE_PROJECT_NAME=warehouse-management
TZ=Europe/London

FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306

DB_NAME=warehouse_management
DB_USERNAME=warehouse_app
DB_PASSWORD=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION_HOURS=8
FLYWAY_ENABLED=true

INIT_ADMIN_ENABLED=true
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change_me_initial_admin_password
INIT_ADMIN_EMAIL=
INIT_ADMIN_PHONE=
