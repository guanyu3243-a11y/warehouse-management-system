# Copy this file to .env before running docker compose.
# Replace every change-me value before using it outside local testing.

COMPOSE_PROJECT_NAME=warehouse-management
TZ=Europe/London

FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306

DB_NAME=warehouse_management
DB_USERNAME=root
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456

JWT_SECRET=please_change_this_to_a_long_random_secret_warehouse_system
JWT_EXPIRATION_HOURS=8
FLYWAY_ENABLED=true
